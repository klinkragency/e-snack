# ═══════════════════════════════════════════════════════════════
# e-Snack — Environment Configuration
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ─── TIER 1: Required (stack won't start without these) ──────

# Public domain — used by Caddy for TLS and by the API for URLs
DOMAIN=example.com
PUBLIC_URL=https://example.com

# PostgreSQL
POSTGRES_USER=esnack
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=esnack_db

# Secrets (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME
COOKIE_SECRET=CHANGE_ME

# Next.js BFF → Go API (internal Docker network, never exposed)
BACKEND_URL=http://api:8080

# ─── TIER 2: First-boot seed (read once, can be removed after) ─

INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=CHANGE_ME
INITIAL_ADMIN_NAME=Admin
INITIAL_RESTAURANT_NAME=Mon Restaurant
INITIAL_RESTAURANT_SLUG=mon-restaurant

# ─── TIER 3: Highly recommended (major features need these) ──

# Email (OTP, order confirmations) — choose Resend OR SMTP
RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=no-reply@example.com

# Online payments (Mollie) — without this, only on-site payment works
MOLLIE_API_KEY=

# Image uploads (MinIO is embedded in docker-compose by default)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_BUCKET=uploads

# ─── TIER 4: Optional (features are hidden when key is empty) ─

# AI menu import (admin button hidden if empty)
OPENAI_API_KEY=

# OAuth login providers (buttons hidden if empty)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
APPLE_OAUTH_CLIENT_ID=

# Telegram driver notifications (module hidden if empty)
TELEGRAM_BOT_TOKEN=

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Error tracking
SENTRY_DSN=

# Feature flags (set to "true" to show corresponding UI)
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false
NEXT_PUBLIC_APPLE_OAUTH_ENABLED=false
NEXT_PUBLIC_AI_IMPORT_ENABLED=false
