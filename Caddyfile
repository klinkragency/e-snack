www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}

{$DOMAIN} {
	# Uploaded files: /uploads/filename → minio:9000/{bucket}/filename
	handle /uploads/* {
		uri replace /uploads/ /{$MINIO_BUCKET:uploads}/
		reverse_proxy minio:9000 {
			header_up Host {upstream_hostport}
		}
		header Cache-Control "public, max-age=31536000, immutable"
	}

	# WebSocket to Go API
	handle /ws/* {
		reverse_proxy api:8080
	}

	# Go REST API (mobile clients call this directly with Bearer tokens)
	handle /api/v1/* {
		reverse_proxy api:8080
	}

	# Everything else to Next.js
	handle {
		reverse_proxy frontend:3000
	}
}
