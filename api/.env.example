# Server
GRPC_PORT=50051
HTTP_PORT=8080
ENV=development

# Database
DATABASE_URL=postgres://beldys:beldys_secret@localhost:5432/beldys_db?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-secure-secret-in-production
JWT_ACCESS_EXPIRY=35m
JWT_REFRESH_EXPIRY=168h

# Admin seed (used on first startup)
ADMIN_EMAIL=admin@beldys.club
ADMIN_PASSWORD=admin123

# UploadThing (for image uploads)
UPLOADTHING_SECRET=

# OAuth
GOOGLE_CLIENT_ID=

# Telegram Bot (for driver notifications)
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=beldys_livreur_bot
TELEGRAM_BOT_URL=https://beldys.mc
